{
  "id": "tjogel-org",
  "start_urls": [
    "https://tjogel.org/past-volumes/"
  ],
  "source": "claude_code_skill",
  "metadata": {
    "journal_name": "Texas Journal of Oil, Gas, and Energy Law",
    "platform": "WordPress",
    "url": "https://tjogel.org/",
    "created_date": "2026-04-01",
    "status": "active",
    "navigation": {
      "archive_root": "https://tjogel.org/past-volumes/",
      "volume_url_pattern": "none-list",
      "archive_path": "homepage -> /past-volumes/ -> individual volumes -> article list -> PDF link",
      "pdf_location": "volume-page-or-detail",
      "notes": "WordPress site. Archive lists past volumes. PDFs are often direct in the volume list."
    }
  },
  "selectors": [
    {
      "id": "volume_link",
      "type": "SelectorLink",
      "selector": ".entry-content a[href*='/volume-']",
      "parentSelectors": ["_root"]
    },
    {
      "id": "article_container",
      "type": "SelectorElement",
      "selector": "article.post, .entry-content p, .entry-content li",
      "parentSelectors": ["volume_link"]
    },
    {
      "id": "title",
      "type": "SelectorText",
      "selector": "strong, b, span.title",
      "parentSelectors": ["article_container"]
    },
    {
      "id": "pdf_link",
      "type": "SelectorLink",
      "selector": "a[href$='.pdf']",
      "parentSelectors": ["article_container"],
      "notes": "PDF in the list"
    }
  ]
}
