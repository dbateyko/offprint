      ]
    },
    {
      "id": "title",
      "type": "SelectorText",
      "selector": "h1, h2, h3, .title, .entry-title",
      "parentSelectors": [
        "article_container"
      ]
    },
    {
      "id": "article_url",
      "type": "SelectorLink",
      "selector": "h1 a, h2 a, h3 a, .title a, a[href*=\"/article/\"], a[href*=\"/issue/\"]",
      "parentSelectors": [
        "article_container"
      ]
    },
    {
      "id": "pdf_link",
      "type": "SelectorLink",
      "selector": "a[href$=\".pdf\"], a[href*=\"/pdf/\"]",
      "parentSelectors": [
        "_root"
      ]
    }
  ]
