{
  "id": "lawreview-uchicago-edu",
  "start_urls": [
    "https://lawreview.uchicago.edu/print-archive",
    "https://lawreview.uchicago.edu/online-archive"
  ],
  "source": "claude_code_skill",
  "metadata": {
    "journal_name": "University of Chicago Law Review",
    "platform": "Drupal",
    "url": "https://lawreview.uchicago.edu/",
    "created_date": "2025-12-14",
    "status": "active",
    "navigation": {
      "archive_root": "https://lawreview.uchicago.edu/print-archive",
      "volume_url_pattern": "none-listing",
      "archive_path": "homepage -> /print-archive lists articles as nodes",
      "pdf_location": "article-detail-page",
      "notes": "Drupal site. Articles are listed on the archive pages. PDFs are direct on the article node page in field-link-pdf."
    }
  },
  "selectors": [
    {
      "id": "article_container",
      "type": "SelectorElement",
      "selector": "article.node--type-publication",
      "parentSelectors": ["_root"]
    },
    {
      "id": "title",
      "type": "SelectorText",
      "selector": ".field--name-title",
      "parentSelectors": ["article_container"]
    },
    {
      "id": "article_url",
      "type": "SelectorLink",
      "selector": "a[rel='bookmark']",
      "parentSelectors": ["article_container"]
    },
    {
      "id": "author",
      "type": "SelectorText",
      "selector": ".author--name",
      "parentSelectors": ["_root"],
      "notes": "Scoped to article detail page"
    },
    {
      "id": "pdf_link",
      "type": "SelectorLink",
      "selector": "a[href$='.pdf']",
      "parentSelectors": ["_root"],
      "notes": "PDF in the field-link-pdf or abstract section"
    }
  ]
}
