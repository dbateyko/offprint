{
  "id": "law-uark-edu-alr",
  "start_urls": [
    "https://law.uark.edu/alr/archives.php"
  ],
  "source": "claude_code_skill",
  "metadata": {
    "journal_name": "Arkansas Law Review",
    "platform": "Custom/PHP",
    "url": "https://law.uark.edu/alr/",
    "created_date": "2026-04-01",
    "status": "active",
    "navigation": {
      "archive_root": "https://law.uark.edu/alr/archives.php",
      "volume_url_pattern": "none-list",
      "archive_path": "homepage -> /archives.php -> volume links -> article detail -> PDF link",
      "pdf_location": "article-detail-page",
      "notes": "University-hosted PHP site. Archive lists volumes. PDFs are direct on article detail pages."
    }
  },
  "selectors": [
    {
      "id": "volume_link",
      "type": "SelectorLink",
      "selector": "a[href*='volume-']",
      "parentSelectors": ["_root"]
    },
    {
      "id": "article_container",
      "type": "SelectorElement",
      "selector": ".article-list-item, .content",
      "parentSelectors": ["volume_link"]
    },
    {
      "id": "title",
      "type": "SelectorText",
      "selector": "h1, h2, h3",
      "parentSelectors": ["article_container"]
    },
    {
      "id": "article_url",
      "type": "SelectorLink",
      "selector": "a[href*='article']",
      "parentSelectors": ["article_container"]
    },
    {
      "id": "pdf_link",
      "type": "SelectorLink",
      "selector": "a[href$='.pdf']",
      "parentSelectors": ["_root"],
      "notes": "PDF on article detail page"
    }
  ]
}
