{
  "id": "cornell-law-review",
  "start_urls": [
    "https://publications.lawschool.cornell.edu/lawreview/archives/issues/"
  ],
  "source": "claude_code_skill",
  "metadata": {
    "journal_name": "Cornell Law Review",
    "platform": "wordpress",
    "url": "https://publications.lawschool.cornell.edu/lawreview/",
    "created_date": "2026-03-27",
    "status": "active",
    "navigation": {
      "archive_root": "https://publications.lawschool.cornell.edu/lawreview/archives/issues/",
      "volume_url_pattern": "none-accordions",
      "archive_path": "homepage -> /archives/issues/ -> accordions -> article pages -> PDF link",
      "pdf_location": "article-detail-page",
      "notes": "WordPress site with REST API active. Articles are listed in accordions on the issues page. PDFs use a file-pdf icon link."
    }
  },
  "selectors": [
    {
      "id": "article_container",
      "type": "SelectorElement",
      "selector": ".c-accordion__content h4",
      "parentSelectors": ["_root"]
    },
    {
      "id": "title",
      "type": "SelectorText",
      "selector": "a",
      "parentSelectors": ["article_container"]
    },
    {
      "id": "article_url",
      "type": "SelectorLink",
      "selector": "a",
      "parentSelectors": ["article_container"]
    },
    {
      "id": "pdf_link",
      "type": "SelectorLink",
      "selector": "a[href$='.pdf']",
      "parentSelectors": ["_root"]
    }
  ]
}
