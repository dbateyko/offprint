{
  "id": "drexellawreview-org",
  "start_urls": [
    "https://drexellawreview.org/archive/"
  ],
  "source": "claude_code_skill",
  "metadata": {
    "journal_name": "Drexel Law Review",
    "platform": "WordPress",
    "url": "https://drexellawreview.org/",
    "created_date": "2026-04-01",
    "status": "active",
    "navigation": {
      "archive_root": "https://drexellawreview.org/archive/",
      "volume_url_pattern": "none-list",
      "archive_path": "homepage -> /archive/ -> current issue -> previous volumes -> volume/issue links -> article detail -> PDF link",
      "pdf_location": "article-detail-page",
      "notes": "WordPress site. Archive contains issue links. PDFs are direct on article detail pages."
    }
  },
  "selectors": [
    {
      "id": "issue_link",
      "type": "SelectorLink",
      "selector": ".archive-issue a, a[href*='/volume-'], a[href*='/v-']",
      "parentSelectors": ["_root"]
    },
    {
      "id": "article_container",
      "type": "SelectorElement",
      "selector": "article.post, .entry-content",
      "parentSelectors": ["issue_link"]
    },
    {
      "id": "title",
      "type": "SelectorText",
      "selector": "h1.entry-title, h2.entry-title a",
      "parentSelectors": ["article_container"]
    },
    {
      "id": "article_url",
      "type": "SelectorLink",
      "selector": "h2.entry-title a, h1.entry-title a",
      "parentSelectors": ["article_container"]
    },
    {
      "id": "pdf_link",
      "type": "SelectorLink",
      "selector": "a[href$='.pdf']",
      "parentSelectors": ["_root"],
      "notes": "PDF on article detail page"
    }
  ]
}
