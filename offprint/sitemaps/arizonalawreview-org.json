{
  "id": "arizonalawreview-org",
  "metadata": {
    "created_date": "2026-04-04",
    "journal_name": "Arizona Law Review",
    "platform": "wordpress",
    "status": "active",
    "url": "https://arizonalawreview.org/",
    "navigation": {
      "archive_root": "https://arizonalawreview.org/print-archive/",
      "article_path": "homepage -> Print Archive -> Issue Page -> Article PDF",
      "pdf_location": "article-link",
      "notes": "Arizona Law Review. WordPress site (WPEX Magtastic theme). Issue pages contain article loop elements with PDF download links."
    }
  },
  "source": "manual",
  "start_urls": [
    "https://arizonalawreview.org/print-archive/"
  ],
  "selectors": [
    {
      "id": "issue_link",
      "type": "SelectorLink",
      "selector": "p a[href*='/issues/']",
      "parentSelectors": [
        "_root"
      ]
    },
    {
      "id": "article_container",
      "type": "SelectorElement",
      "selector": "article.loop-entry",
      "parentSelectors": [
        "issue_link"
      ]
    },
    {
      "id": "title",
      "type": "SelectorText",
      "selector": "h2.loop-entry-title a",
      "parentSelectors": [
        "article_container"
      ]
    },
    {
      "id": "article_url",
      "type": "SelectorLink",
      "selector": "h2.loop-entry-title a",
      "parentSelectors": [
        "article_container"
      ]
    },
    {
      "id": "pdf_link",
      "type": "SelectorLink",
      "selector": "a.download",
      "parentSelectors": [
        "article_container"
      ]
    }
  ]
}