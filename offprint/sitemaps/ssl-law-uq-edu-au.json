{
  "id": "ssl-law-uq-edu-au",
  "start_urls": [
    "https://ssl.law.uq.edu.au/journals/index.php/maritimejournal/"
  ],
  "source": "selector_seed",
  "metadata": {
    "journal_name": "Australian and New Zealand Maritime Law Journal",
    "platform": "ojs",
    "url": "https://ssl.law.uq.edu.au/journals/index.php/maritimejournal/",
    "created_date": "2026-04-13",
    "status": "paused_other"
  },
  "selectors": [
    {
      "id": "article_container",
      "type": "SelectorElement",
      "selector": ".obj_article_summary, .article-summary, .tocArticle, .media, article",
      "parentSelectors": [
        "_root"
      ]
    },
    {
      "id": "title",
      "type": "SelectorText",
      "selector": ".obj_article_summary .title, .title a, h3.title a, h2.title a",
      "parentSelectors": [
        "article_container"
      ]
    },
    {
      "id": "article_url",
      "type": "SelectorLink",
      "selector": ".obj_article_summary .title a, .title a, a[href*=\"/article/view/\"]",
      "parentSelectors": [
        "article_container"
      ]
    },
    {
      "id": "pdf_link",
      "type": "SelectorLink",
      "selector": "a[href$=\".pdf\"], a[href*=\"/pdf/\"]",
      "parentSelectors": [
        "_root"
      ]
    }
  ]
}
