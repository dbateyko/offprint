{
  "id": "lawreview-colorado-edu",
  "start_urls": [
    "https://lawreview.colorado.edu/archive/"
  ],
  "source": "claude_code_skill",
  "metadata": {
    "journal_name": "University of Colorado Law Review",
    "platform": "WordPress",
    "url": "https://lawreview.colorado.edu/",
    "created_date": "2026-04-01",
    "status": "active",
    "navigation": {
      "archive_root": "https://lawreview.colorado.edu/archive/",
      "volume_url_pattern": "/volume-\\d+/",
      "archive_path": "homepage -> /archive/ -> volume pages -> category issue links -> article detail -> PDF link",
      "pdf_location": "article-detail-page",
      "notes": "WordPress site. Archive is nested via volume and issue categories. PDFs are direct on article detail pages."
    }
  },
  "selectors": [
    {
      "id": "volume_link",
      "type": "SelectorLink",
      "selector": ".menu-item a[href*='/volume-']",
      "parentSelectors": ["_root"]
    },
    {
      "id": "issue_link",
      "type": "SelectorLink",
      "selector": ".cat-item a",
      "parentSelectors": ["volume_link"]
    },
    {
      "id": "article_container",
      "type": "SelectorElement",
      "selector": "article.post",
      "parentSelectors": ["issue_link"]
    },
    {
      "id": "title",
      "type": "SelectorText",
      "selector": "h1.entry-title, h2.entry-title a",
      "parentSelectors": ["article_container"]
    },
    {
      "id": "article_url",
      "type": "SelectorLink",
      "selector": "h2.entry-title a, h1.entry-title a",
      "parentSelectors": ["article_container"]
    },
    {
      "id": "pdf_link",
      "type": "SelectorLink",
      "selector": "a[href$='.pdf']",
      "parentSelectors": ["_root"],
      "notes": "PDF on article detail page"
    }
  ]
}
