    "archive_url": "https://epj.us/issues",
    "original_url": "https://epj.us/",
    "status": "active",
    "created_date": "2026-05-09",
    "navigation": {
      "pagination_type": "none",
    "notes": "GoDaddy site. /issues lists Volume 1 through Volume 18 without pagination. Volume pages link to issue pages; older volume pages expose article citation text and Read anchors. The selector smoke seed uses Volume 11 because it exposes authors, volume, and 2018/2019 years in HTML; current Volume 18 issue page exposes direct PDFs but sparse article metadata."
    }
  }
