    {
      "id": "title",
      "type": "SelectorText",
      "parentSelectors": [
        "article_container"
      ],
      "selector": "div[data-aid^=\"ABOUT_DESCRIPTION_RENDERED\"]",
      "multiple": false
    },
    {
      "id": "author",
      "type": "SelectorText",
      "parentSelectors": [
        "article_container"
      ],
      "selector": "div[data-aid^=\"ABOUT_DESCRIPTION_RENDERED\"]",
      "multiple": false
    },
    {
      "id": "volume",
      "type": "SelectorText",
      "parentSelectors": [
        "article_container"
      ],
      "selector": "div[data-aid^=\"ABOUT_DESCRIPTION_RENDERED\"]",
      "multiple": false
    },
    {
      "id": "year",
      "type": "SelectorText",
      "parentSelectors": [
        "article_container"
      ],
      "selector": "div[data-aid^=\"ABOUT_DESCRIPTION_RENDERED\"]",
      "multiple": false
    },
    {
      "id": "article_url",
      "type": "SelectorLink",
      "parentSelectors": [
