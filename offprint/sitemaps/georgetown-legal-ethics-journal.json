{
  "id": "georgetown-legal-ethics-journal",
  "start_urls": [
    "https://www.law.georgetown.edu/legal-ethics-journal/in-print/"
  ],
  "source": "claude_code_skill",
  "metadata": {
    "journal_name": "Georgetown Journal of Legal Ethics",
    "platform": "WordPress",
    "url": "https://www.law.georgetown.edu/legal-ethics-journal/",
    "created_date": "2026-04-01",
    "status": "active",
    "navigation": {
      "archive_root": "https://www.law.georgetown.edu/legal-ethics-journal/in-print/",
      "volume_url_pattern": "none-list",
      "archive_path": "homepage -> /in-print/ -> individual volumes -> article detail -> PDF link",
      "pdf_location": "article-detail-page",
      "notes": "Georgetown-hosted WordPress site. Archive lists past volumes. PDFs are direct on article detail pages."
    }
  },
  "selectors": [
    {
      "id": "volume_link",
      "type": "SelectorLink",
      "selector": ".entry-content a[href*='/volume-']",
      "parentSelectors": ["_root"]
    },
    {
      "id": "article_container",
      "type": "SelectorElement",
      "selector": "article.post, .node-article",
      "parentSelectors": ["volume_link"]
    },
    {
      "id": "title",
      "type": "SelectorText",
      "selector": "h1, h2 a",
      "parentSelectors": ["article_container"]
    },
    {
      "id": "article_url",
      "type": "SelectorLink",
      "selector": "h2 a, h1 a",
      "parentSelectors": ["article_container"]
    },
    {
      "id": "pdf_link",
      "type": "SelectorLink",
      "selector": "a[href$='.pdf']",
      "parentSelectors": ["_root"],
      "notes": "PDF link on article page."
    }
  ]
}
