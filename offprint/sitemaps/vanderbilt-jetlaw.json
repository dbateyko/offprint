{
  "id": "vanderbilt-jetlaw",
  "start_urls": [
    "https://www.vanderbilt.edu/jetlaw/past-volumes/"
  ],
  "source": "claude_code_skill",
  "metadata": {
    "journal_name": "Vanderbilt Journal of Entertainment and Technology Law",
    "platform": "WordPress",
    "url": "https://www.vanderbilt.edu/jetlaw/",
    "created_date": "2026-04-01",
    "status": "active",
    "navigation": {
      "archive_root": "https://www.vanderbilt.edu/jetlaw/past-volumes/",
      "volume_url_pattern": "none-list",
      "archive_path": "homepage -> /past-volumes/ -> individual volumes -> article detail -> PDF link",
      "pdf_location": "article-detail-page",
      "notes": "WordPress site. Volumes and issues are listed. PDFs are direct on article detail pages."
    }
  },
  "selectors": [
    {
      "id": "volume_link",
      "type": "SelectorLink",
      "selector": ".menu-item a[href*='/volume-'], a[href*='/volume/']",
      "parentSelectors": ["_root"]
    },
    {
      "id": "article_container",
      "type": "SelectorElement",
      "selector": "article.post, .sqs-block-content",
      "parentSelectors": ["volume_link"]
    },
    {
      "id": "title",
      "type": "SelectorText",
      "selector": "h1.entry-title, h2.entry-title a",
      "parentSelectors": ["article_container"]
    },
    {
      "id": "article_url",
      "type": "SelectorLink",
      "selector": "h2.entry-title a, h1.entry-title a",
      "parentSelectors": ["article_container"]
    },
    {
      "id": "pdf_link",
      "type": "SelectorLink",
      "selector": "a[href$='.pdf']",
      "parentSelectors": ["_root"],
      "notes": "PDF on article detail page"
    }
  ]
}
