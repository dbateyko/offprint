  "selectors": [
    {
      "id": "article_container",
      "type": "SelectorElement",
      "selector": "article > figure",
      "parentSelectors": [
        "_root"
      ]
    },
    {
      "id": "title",
      "type": "SelectorText",
      "selector": "h3.li-title a",
      "parentSelectors": [
        "article_container"
      ]
    },
    {
      "id": "author",
      "type": "SelectorText",
      "selector": "h5.li-meta em",
      "parentSelectors": [
        "article_container"
      ],
      "notes": "First <em> element in h5.li-meta contains author name"
    },
    {
      "id": "date",
      "type": "SelectorText",
      "selector": "h5.li-meta time em",
      "parentSelectors": [
        "article_container"
      ]
    },
    {
      "id": "article_url",
      "type": "SelectorLink",
      "selector": "h3.li-title a",
      "parentSelectors": [
        "article_container"
      ]
    },
    {
      "id": "next_page",
      "type": "SelectorLink",
      "selector": "a[rel=\"next\"]",
      "parentSelectors": [
        "_root"
      ]
    }
  ]
