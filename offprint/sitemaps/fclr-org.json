{
  "id": "fclr-org",
  "start_urls": [
    "https://www.fclr.org/fclr/index.php/fclr/issue/archive"
  ],
  "source": "claude_code_skill",
  "metadata": {
    "journal_name": "Federal Courts Law Review",
    "platform": "OJS",
    "url": "https://www.fclr.org/",
    "created_date": "2026-04-01",
    "status": "active",
    "navigation": {
      "archive_root": "https://www.fclr.org/fclr/index.php/fclr/issue/archive",
      "volume_url_pattern": "none-list",
      "archive_path": "homepage -> /fclr/ -> /issue/archive -> individual issues -> article detail -> PDF link",
      "pdf_location": "article-detail-page",
      "notes": "OJS-based site. Archive contains issue links. PDFs are direct on article detail pages."
    }
  },
  "selectors": [
    {
      "id": "issue_link",
      "type": "SelectorLink",
      "selector": ".obj_issue_summary a.title, a[href*='/issue/view/']",
      "parentSelectors": ["_root"]
    },
    {
      "id": "article_container",
      "type": "SelectorElement",
      "selector": ".obj_article_summary",
      "parentSelectors": ["issue_link"]
    },
    {
      "id": "title",
      "type": "SelectorText",
      "selector": ".title a",
      "parentSelectors": ["article_container"]
    },
    {
      "id": "article_url",
      "type": "SelectorLink",
      "selector": ".title a",
      "parentSelectors": ["article_container"]
    },
    {
      "id": "pdf_link",
      "type": "SelectorLink",
      "selector": "a.obj_galley_link.pdf",
      "parentSelectors": ["_root"],
      "notes": "PDF on article detail page"
    }
  ]
}
