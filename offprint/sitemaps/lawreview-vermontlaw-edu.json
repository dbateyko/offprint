    "status_reason": "lawreview.vermontlaw.edu is a live WordPress site with PDFs at /wp-content/uploads/. Host is not registered in adapters/registry.py to WordPressAcademicBaseAdapter, so it falls through to GenericAdapter which doesn't get the WP fast-mode benefits (wp-sitemap.xml + wp-json scan). Needs registry registration as WordPressAcademicBaseAdapter to discover PDFs reliably.",
    "status_updated_at": "2026-05-05T02:21:20Z",
    "status_evidence_ref": "lawreview.vermontlaw.edu/past-issues/ -> 200 with /wp-content/uploads/YYYY/MM/*.pdf links visible",
    "navigation": {
      "archive_root": "https://lawreview.vermontlaw.edu/past-issues/",
      "volume_url_pattern": "none-list",
      "archive_path": "homepage -> /past-issues/ -> individual books -> article detail -> PDF link",
      "pdf_location": "article-detail-page",
      "notes": "WordPress site. Archive lists past books/issues. PDFs are direct on article detail pages."
    }
  },
  "selectors": [
    {
      "id": "issue_link",
      "type": "SelectorLink",
      "selector": ".entry-content a[href*='/past-issues/volume-']",
      "parentSelectors": ["_root"]
    },
    {
      "id": "article_container",
      "type": "SelectorElement",
      "selector": "article.post, .entry-content",
      "parentSelectors": ["issue_link"]
    },
    {
      "id": "title",
      "type": "SelectorText",
      "selector": "h1.entry-title, h2.entry-title a",
      "parentSelectors": ["article_container"]
    },
    {
      "id": "article_url",
      "type": "SelectorLink",
      "selector": "h2.entry-title a, h1.entry-title a",
      "parentSelectors": ["article_container"]
    },
    {
      "id": "pdf_link",
      "type": "SelectorLink",
      "selector": "a[href$='.pdf']",
      "parentSelectors": ["_root"],
      "notes": "PDF on article detail page"
    }
  ]
}
