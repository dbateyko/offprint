{
  "id": "wlr-law-wisc-edu",
  "start_urls": [
    "https://wlr.law.wisc.edu/past-issues/"
  ],
  "source": "claude_code_skill",
  "metadata": {
    "journal_name": "Wisconsin Law Review",
    "platform": "WordPress",
    "url": "https://wlr.law.wisc.edu/",
    "created_date": "2026-04-01",
    "status": "active",
    "navigation": {
      "archive_root": "https://wlr.law.wisc.edu/past-issues/",
      "volume_url_pattern": "/volume-\\d+/",
      "archive_path": "homepage -> /past-issues/ -> issue links -> article detail -> PDF link",
      "pdf_location": "article-detail-page",
      "notes": "WordPress site. Issues are listed as separate pages or categories. PDFs are direct on article detail pages."
    }
  },
  "selectors": [
    {
      "id": "issue_link",
      "type": "SelectorLink",
      "selector": "a[href*='/volume-']",
      "parentSelectors": ["_root"]
    },
    {
      "id": "article_container",
      "type": "SelectorElement",
      "selector": "article.post",
      "parentSelectors": ["issue_link"]
    },
    {
      "id": "title",
      "type": "SelectorText",
      "selector": "h1.entry-title, h2.entry-title a",
      "parentSelectors": ["article_container"]
    },
    {
      "id": "article_url",
      "type": "SelectorLink",
      "selector": "h2.entry-title a, h1.entry-title a",
      "parentSelectors": ["article_container"]
    },
    {
      "id": "pdf_link",
      "type": "SelectorLink",
      "selector": "a[href$='.pdf']",
      "parentSelectors": ["_root"],
      "notes": "PDF on article detail page"
    }
  ]
}
