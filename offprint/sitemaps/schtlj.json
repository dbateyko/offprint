{
  "id": "schtlj",
  "start_urls": [
    "https://digitalcommons.law.scu.edu/chtlj/all_issues.html"
  ],
  "source": "csv",
  "raw_sitemap": {
    "_id": "schtlj",
    "startUrl": [
      "https://digitalcommons.law.scu.edu/chtlj/all_issues.html"
    ],
    "selectors": [
      {
        "id": "issue",
        "parentSelectors": [
          "_root"
        ],
        "type": "SelectorLink",
        "selector": ".issue a",
        "multiple": true,
        "linkType": "linkFromHref"
      },
      {
        "id": "articles",
        "parentSelectors": [
          "issue"
        ],
        "type": "SelectorElement",
        "selector": "div.doc",
        "multiple": true,
        "scroll": false,
        "elementLimit": 0
      },
      {
        "id": "title",
        "parentSelectors": [
          "articles"
        ],
        "type": "SelectorText",
        "selector": "p:nth-of-type(2) a",
        "multiple": false,
        "regex": "",
        "multipleType": "singleColumn"
      },
      {
        "id": "author",
        "parentSelectors": [
          "articles"
        ],
        "type": "SelectorText",
        "selector": "span",
        "multiple": false,
        "regex": "",
        "multipleType": "singleColumn"
      },
      {
        "id": "pdf",
        "parentSelectors": [
          "articles"
        ],
        "type": "SelectorLink",
        "selector": ".pdf a",
        "multiple": false,
        "linkType": "linkFromHref"
      },
      {
        "id": "volume_and_date",
        "parentSelectors": [
          "issue"
        ],
        "type": "SelectorText",
        "selector": "#alpha h1",
        "multiple": false,
        "regex": "",
        "multipleType": "singleColumn"
      }
    ]
  }
}