{
  "id": "lawjournal-ku-edu",
  "start_urls": [
    "https://lawjournal.ku.edu/archives/"
  ],
  "source": "claude_code_skill",
  "metadata": {
    "journal_name": "Kansas Journal of Law & Public Policy",
    "platform": "WordPress",
    "url": "https://lawjournal.ku.edu/",
    "created_date": "2026-04-01",
    "status": "active",
    "navigation": {
      "archive_root": "https://lawjournal.ku.edu/archives/",
      "volume_url_pattern": "none-list",
      "archive_path": "homepage -> /archives/ -> individual volumes -> article detail -> PDF link",
      "pdf_location": "article-detail-page",
      "notes": "WordPress site. Archive lists past volumes. PDFs are direct on article detail pages."
    }
  },
  "selectors": [
    {
      "id": "article_container",
      "type": "SelectorElement",
      "selector": "article, .article, .post, .entry, li",
      "parentSelectors": [
        "_root"
      ]
    },
    {
      "id": "title",
      "type": "SelectorText",
      "selector": "h1, h2, h3, .title, .entry-title",
      "parentSelectors": [
        "article_container"
      ]
    },
    {
      "id": "article_url",
      "type": "SelectorLink",
      "selector": "h1 a, h2 a, h3 a, .title a, a[href*=\"/article/\"], a[href*=\"/issue/\"]",
      "parentSelectors": [
        "article_container"
      ]
    },
    {
      "id": "pdf_link",
      "type": "SelectorLink",
      "selector": "a[href$=\".pdf\"], a[href*=\"/pdf/\"]",
      "parentSelectors": [
        "_root"
      ]
    }
  ]
}
