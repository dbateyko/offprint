{
  "id": "socialchangenyu-com",
  "start_urls": [
    "https://socialchangenyu.com/past-volumes/"
  ],
  "source": "claude_code_skill",
  "metadata": {
    "journal_name": "New York University Review of Law & Social Change",
    "platform": "Squarespace",
    "url": "https://socialchangenyu.com/",
    "created_date": "2026-04-01",
    "status": "active",
    "navigation": {
      "archive_root": "https://socialchangenyu.com/past-volumes/",
      "volume_url_pattern": "none-list",
      "archive_path": "homepage -> /past-volumes/ -> individual volumes -> article detail -> PDF link",
      "pdf_location": "article-detail-page",
      "notes": "Squarespace site. Volumes and issues are listed. PDFs are direct on article detail pages."
    }
  },
  "selectors": [
    {
      "id": "volume_link",
      "type": "SelectorLink",
      "selector": ".menu-item a[href*='/volume-'], a[href*='/volume/']",
      "parentSelectors": ["_root"]
    },
    {
      "id": "article_container",
      "type": "SelectorElement",
      "selector": "article.post, .sqs-block-content",
      "parentSelectors": ["volume_link"]
    },
    {
      "id": "title",
      "type": "SelectorText",
      "selector": "h1.entry-title, h2.entry-title a",
      "parentSelectors": ["article_container"]
    },
    {
      "id": "article_url",
      "type": "SelectorLink",
      "selector": "h2.entry-title a, h1.entry-title a",
      "parentSelectors": ["article_container"]
    },
    {
      "id": "pdf_link",
      "type": "SelectorLink",
      "selector": "a[href$='.pdf']",
      "parentSelectors": ["_root"],
      "notes": "PDF on article detail page"
    }
  ]
}
